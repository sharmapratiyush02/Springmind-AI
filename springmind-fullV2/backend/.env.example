# SpringMind AI — Backend Environment Variables
# Have to copy this file to .env and fill in my values for production

# JWT Secret — minimum 32 characters, use a random string in production
JWT_SECRET=SpringMindAI_JWT_Secret_Key_Min32Chars_2026!

# Database — Railway sets DATABASE_URL automatically
DATABASE_URL=jdbc:postgresql://localhost:5432/springmind_db
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_DRIVER=org.postgresql.Driver
JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
DDL_AUTO=update

# Profile — set to production on Railway
SPRING_PROFILES_ACTIVE=production

# CORS — set to your Vercel frontend URL after deployment
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email — optional, set EMAIL_ENABLED=true to activate
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
EMAIL_ENABLED=false

# Server port — Railway sets PORT automatically
PORT=8080